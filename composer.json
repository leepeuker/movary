{
  "name": "leepe/movary",
  "type": "project",
  "authors": [
    {
      "name": "Lee Peuker",
      "email": "lee.peuker@protonmail.com"
    }
  ],
  "require": {
    "php": "^8.5",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-zlib": "*",
    "doctrine/dbal": "^3.9",
    "guzzlehttp/guzzle": "^7.10",
    "league/csv": "^9.28",
    "maennchen/zipstream-php": "^3.2",
    "monolog/monolog": "^3.10",
    "nikic/fast-route": "^1.3",
    "php-di/php-di": "^7.0",
    "phpmailer/phpmailer": "^7.0",
    "psr/http-client": "^1.0.3",
    "ramsey/uuid": "^4.9",
    "robmorgan/phinx": "^0.16",
    "spomky-labs/otphp": "^11.4",
    "symfony/console": "^7.1",
    "twig/twig": "^3.26",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "^3.13",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "vimeo/psalm": "^6.16",
    "psalm/plugin-phpunit": "^0.19"
  },
  "scripts": {
    "test": [
      "@test-cs",
      "@test-phpstan",
      "@test-psalm",
      "@test-unit"
    ],
    "test-cs": "phpcs --standard=./settings/phpcs.xml",

    "test-phpstan": "phpstan analyse --memory-limit 512M -c ./settings/phpstan.neon",
    "test-psalm": "psalm -c ./settings/psalm.xml --show-info=false",
    "test-unit": "phpunit -c ./settings/phpunit.xml --testsuite unit"
  },
  "autoload": {
    "psr-4": {
      "Movary\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Unit\\Movary\\": "tests/unit/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
